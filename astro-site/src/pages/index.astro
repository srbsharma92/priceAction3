---
import '../styles/theme.css';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NSE Live Price Action | Smart Money Terminal</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📈</text></svg>" />
  </head>
  <body>
    <div class="wrap">
      <div class="hero-card">
        <div class="hero-eyebrow">NSE &nbsp;•&nbsp; Institutional Grade Screener</div>
        <div class="hero-title">Live Price Action Terminal</div>
        <div class="hero-subtitle">Track where the Smart Money of Big Fund Houses is moving — in real time</div>
      </div>

      <div class="controls-card">
        <div class="checkbox-row">
          <input type="checkbox" id="fo-checkbox" checked />
          <label for="fo-checkbox">Only F&amp;O Stocks</label>
        </div>
        <div class="status-pill-wrap" id="status-pill-wrap">
          <span class="status-pill">
            <span class="status-dot"></span>
            <span class="status-label">Loading…</span>
          </span>
        </div>
      </div>

      <div class="tab-list">
        <button class="tab-btn active" data-tab="5m">⏱️ 5 Minutes</button>
        <button class="tab-btn" data-tab="15m">⏳ 15 Minutes</button>
        <button class="tab-btn" data-tab="D">📅 Today</button>
        <button class="tab-btn" data-tab="open">🔔 Pre-Open Market</button>
      </div>

      <div class="tab-panel active" id="panel-5m"></div>
      <div class="tab-panel" id="panel-15m"></div>
      <div class="tab-panel" id="panel-D"></div>
      <div class="tab-panel" id="panel-open"></div>

      <div class="footer-quote">"All a person needs to do is observe what the market is telling him &amp; evaluate it" — Jesse Livermore</div>
      <div class="footer-name">Developed by Saurabh Sharma</div>
      <p class="footer-contact"><a href="mailto:srb_sharma@outlook.com">✉️ Contact @ srb_sharma@outlook.com</a></p>
      <p class="footer-note">**Only Stocks with Traded value above 10L</p>
    </div>

    <script type="module">
      import { initApp } from '../scripts/app.js';
      initApp();
    </script>
  </body>
</html>
